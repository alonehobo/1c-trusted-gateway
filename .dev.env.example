# Локальные параметры проекта для правил и агентов
#
# Скопируйте файл в `.dev.env` и заполните только те значения,
# которые действительно нужны в конкретном проекте.
# Если файла нет или параметры пустые, агенты должны
# опираться на `AGENTS.md`, `.memory/PROJECT.md` и локальные правила.

# Короткий код проекта или команды.
PROJECT_CODE=

# Короткое имя компании или продукта.
COMPANY=

# Идентификатор разработчика для локальных шаблонов.
DEVELOPER=

# Основной стек или рантайм.
STACK=

# Основная ветка репозитория.
DEFAULT_BRANCH=main

# Базовый URL dev-стенда или приложения.
DEV_BASE_URL=

# Команда запуска тестов.
TEST_COMMAND=

# Команда сборки или проверки качества.
CHECK_COMMAND=
